# ============================================================================
# CLOUDFLARE TURNSTILE CONFIGURATION
# ============================================================================
# Complete setup guide for Cloudflare Turnstile bot protection
# This is adapted for Onetera fintech payment platform
#
# DOCUMENTATION: https://developers.cloudflare.com/turnstile/
# ============================================================================

# ============================================================================
# 1. BASIC CREDENTIALS (Required)
# ============================================================================
# Get these from: https://dash.cloudflare.com/
# Path: Websites → Your Domain → Turnstile → Overview

# Your Turnstile Site Key (PUBLIC - safe to expose in frontend)
# This identifies your site to Cloudflare
CLOUDFLARE_TURNSTILE_SITE_KEY=0x4AAAAAAAAbCdE12345FgHiJ_KlMnOpQr

# Your Turnstile Secret Key (PRIVATE - keep this secret!)
# This is used server-side to verify tokens
# NEVER commit this to version control
CLOUDFLARE_TURNSTILE_SECRET_KEY=0x4AAAAAAAAbCdE12345FgHiJ_KlMnOpQr_SecretKey

# ============================================================================
# 2. DISPLAY SETTINGS
# ============================================================================
# Theme for the Turnstile widget appearance
# Options: auto, light, dark
# Default: auto (follows user's system preference)
CLOUDFLARE_TURNSTILE_THEME=auto

# Widget size/display mode
# Options: normal, compact, invisible
# normal - Full size widget
# compact - Smaller widget for space-constrained areas
# invisible - Hidden widget (used in dashboard, non-intrusive)
CLOUDFLARE_TURNSTILE_SIZE=normal

# ============================================================================
# 3. WIDGET MODES
# ============================================================================
# MANAGED WIDGET (visible - used for forms)
# Location: resources/views/user/partials/turnstile.blade.php
# Type: Visible interactive challenge for user to complete
# Use for: Login, Registration, Contact Forms, Public Forms
MANAGED_WIDGET_ENABLED=true

# INVISIBLE WIDGET (hidden - used for dashboard)
# Location: resources/views/livewire/invisible-turnstile.blade.php
# Type: Non-intrusive background verification
# Use for: Dashboard, Protected Operations, API Calls
INVISIBLE_WIDGET_ENABLED=true

# ============================================================================
# 4. SECURITY SETTINGS
# ============================================================================
# Enable Turnstile entirely (can disable for testing)
TURNSTILE_ENABLED=true

# Require Turnstile for all authenticated routes
TURNSTILE_REQUIRE_AUTH=true

# Require Turnstile for all guest routes (login, register, contact)
TURNSTILE_REQUIRE_GUEST=true

# Rate limiting - max verification attempts per IP per timeframe
TURNSTILE_RATE_LIMIT_ATTEMPTS=5
TURNSTILE_RATE_LIMIT_MINUTES=1

# IP Blocking - block suspicious IPs after failed attempts
TURNSTILE_IP_BLOCK_ENABLED=true
TURNSTILE_IP_BLOCK_THRESHOLD=10
TURNSTILE_IP_BLOCK_DURATION_HOURS=24

# Session protection - invalidate token after certain actions
TURNSTILE_SESSION_PROTECTION=true
TURNSTILE_SESSION_TIMEOUT_MINUTES=15

# ============================================================================
# 5. ADVANCED SETTINGS
# ============================================================================
# HTTP request timeout for Turnstile API verification
# Recommended: 10 seconds (balance between speed and reliability)
TURNSTILE_REQUEST_TIMEOUT=10

# Retry failed verifications
TURNSTILE_RETRY_ENABLED=true
TURNSTILE_RETRY_MAX_ATTEMPTS=3

# Auto-retry interval (milliseconds)
TURNSTILE_RETRY_INTERVAL_MS=8000

# Refresh token before expiry
TURNSTILE_AUTO_REFRESH_ENABLED=true
TURNSTILE_AUTO_REFRESH_BEFORE_EXPIRY_MS=300000 # 5 minutes before expiry

# ============================================================================
# 6. LOGGING & DEBUGGING
# ============================================================================
# Enable detailed Turnstile logging
TURNSTILE_DEBUG=false

# Log channel for Turnstile operations
# Options: single, daily, slack, stack
# See config/logging.php for channel definitions
TURNSTILE_LOG_CHANNEL=daily

# Log security events
TURNSTILE_LOG_SECURITY_EVENTS=true

# Log failed verifications
TURNSTILE_LOG_FAILED_VERIFICATIONS=true

# ============================================================================
# 7. OPTIONAL: CLOUDFLARE RECAPTCHA V3 (Legacy)
# ============================================================================
# If you need reCAPTCHA v3 alongside Turnstile
# Get these from: https://www.google.com/recaptcha/admin

# CLOUDFLARE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
# CLOUDFLARE_RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# ============================================================================
# IMPLEMENTATION CHECKLIST
# ============================================================================
# 
# ✅ Step 1: Get Credentials
#    - Go to: https://dash.cloudflare.com/
#    - Select your domain
#    - Navigate to: Turnstile
#    - Copy Site Key and Secret Key
#
# ✅ Step 2: Add to .env
#    - Copy CLOUDFLARE_TURNSTILE_SITE_KEY value
#    - Copy CLOUDFLARE_TURNSTILE_SECRET_KEY value
#    - Paste into your .env file
#
# ✅ Step 3: Configure Widget Types
#    - MANAGED_WIDGET_ENABLED=true (for forms)
#    - INVISIBLE_WIDGET_ENABLED=true (for dashboard)
#
# ✅ Step 4: Test
#    - Login: http://localhost:8000/user/login
#    - Should see visible Turnstile widget
#    - Dashboard: http://localhost:8000/user/home
#    - Should see invisible Turnstile (check console)
#
# ✅ Step 5: Verify in Code
#    - Run: php artisan tinker
#    - Check: config('services.cloudflare.turnstile_site_key')
#    - Should return your site key
#
# ✅ Step 6: Clear Cache
#    - Run: php artisan config:cache
#
# ============================================================================
# SECURITY NOTES
# ============================================================================
#
# 🔒 DO:
#    - Keep SECRET_KEY private (never commit to Git)
#    - Use SITE_KEY for frontend rendering
#    - Verify tokens server-side
#    - Monitor failed verification attempts
#    - Rotate keys periodically
#
# ❌ DON'T:
#    - Expose SECRET_KEY in frontend code
#    - Trust tokens without server verification
#    - Disable Turnstile in production
#    - Ignore rate limiting settings
#    - Commit .env file to version control
#
# ============================================================================
# TROUBLESHOOTING
# ============================================================================
#
# Problem: Widget not showing
# Solution: Verify CLOUDFLARE_TURNSTILE_SITE_KEY is set correctly
#          Clear browser cache (Ctrl+Shift+Del)
#          Check browser console for errors
#
# Problem: Verification fails
# Solution: Verify SECRET_KEY is correct
#          Check token is being sent in request
#          Verify network connectivity to Cloudflare
#          Check TURNSTILE_REQUEST_TIMEOUT setting
#
# Problem: Too many failed attempts
# Solution: Check TURNSTILE_RATE_LIMIT_ATTEMPTS setting
#          Review IP blocking logs
#          Whitelist legitimate IPs if needed
#
# ============================================================================
# IMPLEMENTATION DETAILS FOR ONETERA
# ============================================================================
#
# MANAGED WIDGET USAGE:
# @include('user.partials.turnstile', ['formId' => 'myForm'])
#
# INVISIBLE WIDGET USAGE:
# @livewire('invisible-turnstile')
#
# VERIFICATION IN CONTROLLER:
# use App\Services\TurnstileService;
# $this->turnstileService->verify($token, request()->ip());
#
# ============================================================================
