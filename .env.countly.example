# Countly Analytics Configuration
# https://countly.com
# 
# Countly is an open-source product analytics platform
# Tracks user behavior, events, and metrics for your fintech application
# Authenticated users only (no admin panel)

# Enable/Disable Countly entirely
COUNTLY_ENABLED=true

# Your Countly Server URL
# For self-hosted: https://your-domain.com
# For Cloud: https://cloud.countly.com
COUNTLY_SERVER_URL=https://cloud.countly.com

# Your Countly Application Key
# Find this in: Countly Dashboard → Settings → Your Apps → App Key
COUNTLY_APP_KEY=your-app-key-here

# Session timeout in minutes
COUNTLY_SESSION_TIMEOUT=15

# Event batch size (events are sent in batches)
COUNTLY_BATCH_SIZE=50

# Batch timeout in seconds
COUNTLY_BATCH_TIMEOUT=60

# HTTP request timeout (seconds)
COUNTLY_REQUEST_TIMEOUT=10

# Log channel for Countly logs
COUNTLY_LOG_CHANNEL=countly

# Debug mode - set to true for detailed logging
COUNTLY_DEBUG=false

# Require explicit user consent (GDPR)
COUNTLY_REQUIRE_CONSENT=false
