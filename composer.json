{
    "name": "laravel/laravel",
    "type": "project",
    "description": "CityPress VTU Script.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "africastalking/africastalking": "^3.0",
        "coingate/coingate-php": "^3.0",
        "ezyang/htmlpurifier": "^4.13",
        "guzzlehttp/guzzle": "^7.0.1",
        "intervention/image": "^2.5",
        "laravel/framework": "^13.0",
        "laravel/nightwatch": "^1.26",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "livewire/flux": "^2.0",
        "livewire/livewire": "^3.7",
        "mailjet/mailjet-apiv3-php": "^1.4",
        "messagebird/php-rest-api": "^1.20",
        "mollie/mollie-api-php": "^2.0",
        "phpmailer/phpmailer": "^6.2",
        "razorpay/razorpay": "^2.5",
        "sendgrid/sendgrid": "^7.6",
        "spatie/laravel-ignition": "^2.0",
        "spatie/laravel-passkeys": "^1.7",
        "stripe/stripe-php": "^7.72",
        "symfony/mailer": "^7.4 || ^8.0",
        "textmagic/sdk": "dev-master",
        "twilio/sdk": "^6.23"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.0",
        "laravel/sail": "^1.30",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "phpunit/phpunit": "^12.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/Http/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
